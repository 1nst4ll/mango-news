---
// Dynamic route for displaying individual articles.
import BaseLayout from '../../layouts/BaseLayout.astro';
import ErrorBoundary from '../../components/ErrorBoundary';
import ArticleDetail from '../../components/ArticleDetail'; // Import as a React component

export const prerender = false; // Mark this page for dynamic rendering

const { id } = Astro.params;

// Fetch article data server-side
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';

let article = null;
try {
  const articleResponse = await fetch(`${apiUrl}/api/articles/${id}`);
  if (articleResponse.ok) {
    article = await articleResponse.json();
  } else if (articleResponse.status === 404) {
    return Astro.redirect('/404');
  }
} catch (error) {
  console.error(`Failed to fetch article with ID ${id}:`, error);
}

// Construct the page title (fallback to generic values if SSR fetch failed)
const pageTitle = article?.title || 'Article';
const pageDescription = article?.summary || (article?.raw_content ? article.raw_content.substring(0, 160) + '...' : 'Read this article on mango.tc news');
const ogImageUrl = article?.thumbnail_url;
const ogUrl = Astro.url.href;
const ogType = "article";
---

<BaseLayout 
  title={pageTitle}
  description={pageDescription}
  ogImageUrl={ogImageUrl}
  ogUrl={ogUrl}
  ogType={ogType}
>
  {/* The ArticleDetail component will fetch data client-side */}
  <ErrorBoundary client:load fallbackMessage="Failed to load article">
    <ArticleDetail id={id} client:load />
  </ErrorBoundary>
</BaseLayout>
