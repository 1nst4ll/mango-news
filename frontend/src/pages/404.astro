---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = false;

Astro.response.status = 404;
---

<BaseLayout title="Page Not Found" sources={[]}>
  <div class="flex flex-col items-center justify-center min-h-[60vh] px-4 text-center">
    <h1 class="text-6xl font-bold text-muted-foreground mb-4">404</h1>
    <p class="text-xl text-muted-foreground mb-8">The page you're looking for doesn't exist.</p>
    <a href="/" class="inline-flex items-center px-6 py-3 rounded-md bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
      Go Home
    </a>
  </div>
</BaseLayout>
